{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "strict": true,
    "noErrorTruncation": true,
    "useDefineForClassFields": true,
    "verbatimModuleSyntax": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "📱/components/*": ["src/components/*"],
      "📱/layouts/*": ["src/layouts/*"],
      "📱/styles/*": ["src/styles/*"],
      "📱/assets/*": ["src/assets/*"],
      "📱/icons/*": ["src/icons/*"],
      "📱/scripts/*": ["src/scripts/*"]
    },
    "jsx": "preserve"
  }
}

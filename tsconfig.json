{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"strict": true,
		"allowJs": true,
		"baseUrl": ".",
		"paths": {
			"📱/components/*": ["src/components/*"],
			"📱/layouts/*": ["src/layouts/*"],
			"📱/styles/*": ["src/styles/*"],
			"📱/assets/*": ["src/assets/*"],
			"📱/icons/*": ["src/icons/*"],
			"📱/scripts/*": ["src/scripts/*"]
		},
		"jsx": "preserve"
	}
}
